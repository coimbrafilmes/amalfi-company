# Bottega by Amalfi & Co. — environment template
# Copia pra .env (real) e ajusta os valores

# Toggle mock vs real (default: mock pra evitar consumo $)
# Pra ativar geração REAL via Gemini + Imagen:
#   VITE_USE_MOCK=false
VITE_USE_MOCK=true

# Google Gemini / Imagen API Key
# Pega em https://aistudio.google.com/apikey
# IMPORTANTE: chaves Vite expostas no client começam com VITE_
# Pra app interna single-user isso é aceitável; pra SaaS, usar proxy backend.
VITE_GEMINI_API_KEY=your-key-here

# Modelo de texto (default: gemini-2.5-flash — rápido e free tier generoso)
VITE_GEMINI_TEXT_MODEL=gemini-2.5-flash

# Modelo de imagem (default: imagen-4.0-generate-001 — alta qualidade, $0.04/img)
VITE_GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
