# Bottega by Amalfi & Co. — environment template
# Copia pra .env (real) e ajusta os valores.
#
# IMPORTANTE: a API key Gemini fica SERVER-SIDE (Netlify Functions),
# nunca no bundle client. As VITE_* abaixo são só pro client.

# === CLIENT (Vite) ===
# Toggle mock vs real (default: mock pra evitar consumo $)
# Pra ativar geração REAL via Functions:
#   VITE_USE_MOCK=false
VITE_USE_MOCK=true

# === SERVER (Netlify Functions) — não prefixadas com VITE_ ===
# Estas variáveis SÓ funcionam quando rodando via `netlify dev` localmente
# ou no painel Netlify (Site settings → Environment variables).
#
# Pega a key em https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# Modelos (default: Flash + Imagen 4)
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
