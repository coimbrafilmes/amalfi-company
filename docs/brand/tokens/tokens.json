{
  "$schema": "https://schemas.dtcg.org/draft/2024-08/dtcg-format.json",
  "$description": "Amalfi & Co. design tokens em formato W3C DTCG. Fonte: docs/brand/Amalfi Co. — Manual de Marca.pdf v1.0 · Maio 2026. Extraído por @ux-design-expert (Uma) em 2026-05-06.",

  "color": {
    "primary": {
      "tinta":     { "$value": "#1F2A3A", "$type": "color", "$description": "Primary 60% · Pantone 5395 C · textos, fundos escuros" },
      "mar":       { "$value": "#2D5D7B", "$type": "color", "$description": "Secondary 25% · Pantone 7700 C · títulos, blocos, links" },
      "terracota": { "$value": "#C47855", "$type": "color", "$description": "Accent 15% · Pantone 7578 C · CTA, lacres, destaques" }
    },
    "secondary": {
      "aqua":  { "$value": "#6E9BB3", "$type": "color" },
      "ceu":   { "$value": "#CFDFE6", "$type": "color" },
      "ocre":  { "$value": "#D4A05A", "$type": "color" },
      "areia": { "$value": "#E6D6BF", "$type": "color" },
      "osso":  { "$value": "#F4EDE0", "$type": "color", "$description": "Background base light mode" }
    },
    "semantic": {
      "bg-base":         { "$value": "{color.secondary.osso}", "$type": "color" },
      "bg-elevated":     { "$value": "#FFFFFF", "$type": "color" },
      "bg-soft":         { "$value": "{color.secondary.areia}", "$type": "color" },
      "bg-inverse":      { "$value": "{color.primary.tinta}", "$type": "color" },
      "text-primary":    { "$value": "{color.primary.tinta}", "$type": "color" },
      "text-inverse":    { "$value": "{color.secondary.osso}", "$type": "color" },
      "action-primary":  { "$value": "{color.primary.tinta}", "$type": "color" },
      "action-accent":   { "$value": "{color.primary.terracota}", "$type": "color" },
      "link":            { "$value": "{color.primary.mar}", "$type": "color" }
    }
  },

  "typography": {
    "fontFamily": {
      "display":   { "$value": "DM Serif Display", "$type": "fontFamily", "$description": "Display — títulos, capas, headlines, logo" },
      "editorial": { "$value": "Cormorant Garamond", "$type": "fontFamily", "$description": "Editorial italic — subtítulos, citações, descrições poéticas" },
      "ui":        { "$value": "Inter", "$type": "fontFamily", "$description": "UI — interfaces, body, botões, etiquetas" }
    },

    "fontWeight": {
      "display":   { "$value": 400, "$type": "fontWeight", "$description": "DM Serif Display Regular" },
      "editorial": { "$value": 400, "$type": "fontWeight", "$description": "Cormorant Italic Regular" },
      "light":     { "$value": 300, "$type": "fontWeight", "$description": "Inter Light — body principal" },
      "regular":   { "$value": 400, "$type": "fontWeight" },
      "medium":    { "$value": 500, "$type": "fontWeight", "$description": "Eyebrows, botões" },
      "semibold":  { "$value": 600, "$type": "fontWeight" }
    },

    "fontSize": {
      "display-xl":   { "$value": "96px", "$type": "dimension" },
      "display-l":    { "$value": "64px", "$type": "dimension" },
      "display-m":    { "$value": "48px", "$type": "dimension" },
      "display-s":    { "$value": "32px", "$type": "dimension" },
      "editorial-xl": { "$value": "32px", "$type": "dimension" },
      "editorial-l":  { "$value": "22px", "$type": "dimension", "$description": "Lede oficial brandbook" },
      "editorial-m":  { "$value": "18px", "$type": "dimension" },
      "h1":      { "$value": "64px", "$type": "dimension" },
      "h2":      { "$value": "48px", "$type": "dimension" },
      "h3":      { "$value": "32px", "$type": "dimension" },
      "body-lg": { "$value": "16px", "$type": "dimension" },
      "body":    { "$value": "14px", "$type": "dimension" },
      "eyebrow": { "$value": "11px", "$type": "dimension" },
      "button":  { "$value": "11px", "$type": "dimension" },
      "meta":    { "$value": "10px", "$type": "dimension" }
    },

    "lineHeight": {
      "display": { "$value": 1.05, "$type": "number" },
      "tight":   { "$value": 1.15, "$type": "number" },
      "normal":  { "$value": 1.4, "$type": "number" },
      "relaxed": { "$value": 1.7, "$type": "number", "$description": "Body principal — sensação arejada" }
    },

    "letterSpacing": {
      "display": { "$value": "-0.015em", "$type": "dimension" },
      "h1":      { "$value": "-0.01em",  "$type": "dimension" },
      "body":    { "$value": "0",        "$type": "dimension" },
      "eyebrow": { "$value": "0.18em",   "$type": "dimension", "$description": "Tracking generoso CAPS" },
      "meta":    { "$value": "0.16em",   "$type": "dimension" }
    },

    "compositeStyles": {
      "h1-display": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.fontFamily.display}",
          "fontWeight": "{typography.fontWeight.display}",
          "fontSize": "{typography.fontSize.h1}",
          "lineHeight": "{typography.lineHeight.display}",
          "letterSpacing": "{typography.letterSpacing.h1}"
        }
      },
      "lede-editorial": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.fontFamily.editorial}",
          "fontWeight": "{typography.fontWeight.editorial}",
          "fontSize": "{typography.fontSize.editorial-l}",
          "lineHeight": "{typography.lineHeight.normal}",
          "fontStyle": "italic"
        }
      },
      "body-ui": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.fontFamily.ui}",
          "fontWeight": "{typography.fontWeight.light}",
          "fontSize": "{typography.fontSize.body-lg}",
          "lineHeight": "{typography.lineHeight.relaxed}"
        }
      },
      "eyebrow-caps": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.fontFamily.ui}",
          "fontWeight": "{typography.fontWeight.medium}",
          "fontSize": "{typography.fontSize.eyebrow}",
          "letterSpacing": "{typography.letterSpacing.eyebrow}",
          "textCase": "uppercase"
        }
      }
    }
  },

  "spacing": {
    "1":  { "$value": "4px",   "$type": "dimension" },
    "2":  { "$value": "8px",   "$type": "dimension" },
    "3":  { "$value": "12px",  "$type": "dimension" },
    "4":  { "$value": "16px",  "$type": "dimension" },
    "5":  { "$value": "24px",  "$type": "dimension" },
    "6":  { "$value": "32px",  "$type": "dimension", "$description": "Mínimo entre seções (princípio brandbook)" },
    "7":  { "$value": "48px",  "$type": "dimension" },
    "8":  { "$value": "64px",  "$type": "dimension" },
    "9":  { "$value": "96px",  "$type": "dimension" },
    "10": { "$value": "144px", "$type": "dimension" }
  },

  "border": {
    "width": {
      "hair":    { "$value": "1px",   "$type": "dimension" },
      "default": { "$value": "1.5px", "$type": "dimension" }
    },
    "radius": {
      "none":   { "$value": "0px",  "$type": "dimension", "$description": "PADRÃO — Amalfi não usa cantos arredondados" },
      "sm":     { "$value": "2px",  "$type": "dimension", "$description": "Exceções raras" },
      "circle": { "$value": "50%",  "$type": "dimension", "$description": "Apenas pra monograma A·co." }
    }
  },

  "duration": {
    "fast": { "$value": "150ms", "$type": "duration" },
    "base": { "$value": "200ms", "$type": "duration" },
    "slow": { "$value": "320ms", "$type": "duration" }
  },

  "combinations": {
    "$description": "Combinações aprovadas (95% dos casos). Use uma como dominante, outra como acento.",
    "serenidade": {
      "$value": {
        "dominant": "{color.primary.tinta}",
        "accent":   "{color.secondary.osso}",
        "use":      "Editorial padrão, base"
      },
      "$type": "other"
    },
    "presenca": {
      "$value": {
        "dominant": "{color.primary.mar}",
        "accent":   "{color.secondary.areia}",
        "use":      "Coleções, campanhas costeiras"
      },
      "$type": "other"
    },
    "calor": {
      "$value": {
        "dominant": "{color.primary.terracota}",
        "accent":   "{color.secondary.osso}",
        "use":      "Promoções, embalagens premium"
      },
      "$type": "other"
    },
    "luz": {
      "$value": {
        "dominant": "{color.secondary.osso}",
        "accent":   "{color.secondary.ocre}",
        "use":      "Coleções verão, papelaria"
      },
      "$type": "other"
    }
  }
}
